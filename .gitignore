# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution and packaging
*.egg
*.egg-info/
dist/
build/
.eggs/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover

# Virtual environments — never commit
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment variables and secrets — NEVER commit
.env
.env.local
.env.*.local
*.env
secrets/
*.key
*.pem
*.crt

# Data — never commit real or large data
data/raw/
data/processed/
data/external/
data/private/
*.csv
*.parquet
*.feather
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini
